# --- Local (Docker Postgres) ---
# docker compose up -d
# DATABASE_URL="postgresql://barbershop:barbershop@localhost:5432/barbershop?schema=public"
# DIRECT_URL="postgresql://barbershop:barbershop@localhost:5432/barbershop?schema=public"

# --- Supabase (recomendado) ---
# Transaction pooler (app / queries) — IPv4
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Session pooler (migraciones Prisma)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Panel dueño (/admin)
ADMIN_PASSWORD="cambia-esta-clave"
ADMIN_SECRET="cadena-larga-aleatoria"

# URL pública (enlaces cancelar/reprogramar en email/WhatsApp)
# APP_URL="https://tudominio.com"

# Zona horaria de la barbería (recordatorios ~24h)
# APP_TIMEZONE="Europe/Madrid"

# Protege /api/cron/reminders (Vercel Cron envía Authorization: Bearer …)
# En local, sin CRON_SECRET el endpoint queda abierto solo en development
# CRON_SECRET="cadena-larga-aleatoria"

# --- Email (Resend) ---
# https://resend.com → API Keys + dominio verificado (o onboarding@resend.dev para tests)
RESEND_API_KEY=
RESEND_FROM_EMAIL="SIGMABARBER <onboarding@resend.dev>"
# Copia opcional al dueño
# NOTIFY_OWNER_EMAIL="dueno@tudominio.com"

# --- WhatsApp (Twilio) ---
# https://console.twilio.com → Account SID / Auth Token
# Sandbox: From = whatsapp:+14155238886 (el cliente debe unirse al sandbox)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Aviso opcional al dueño
# NOTIFY_OWNER_WHATSAPP="+34600000000"
