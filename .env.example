# --- Local (Docker Postgres) ---
# docker compose up -d
DATABASE_URL="postgresql://barbershop:barbershop@localhost:5432/barbershop?schema=public"

# --- Staging / producción (elige uno) ---
# Neon:      DATABASE_URL="postgresql://USER:PASS@HOST/db?sslmode=require"
# Supabase:  DATABASE_URL="postgresql://postgres:PASS@db.PROJECT.supabase.co:5432/postgres"
# Railway:   DATABASE_URL="postgresql://..."

# Panel dueño (/admin)
ADMIN_PASSWORD="cambia-esta-clave"
ADMIN_SECRET="cadena-larga-aleatoria"

