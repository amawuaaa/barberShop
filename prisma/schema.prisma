// Prisma schema — SIGMABARBER
// Provider: PostgreSQL (Docker local / Neon · Supabase · Railway en staging)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Session pooler / direct — required for migrate on Supabase
  directUrl = env("DIRECT_URL")
}

model Barber {
  id             String               @id @default(cuid())
  name           String
  specialty      String
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  appointments   Appointment[]
  availabilities BarberAvailability[]
  exceptions     BarberException[]
}

model Service {
  id           String        @id @default(cuid())
  name         String
  /// Duración estimada en minutos
  duration     Int
  /// Precio en céntimos (1800 = 18 €)
  price        Int
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

/// Horario semanal por barbero (0=domingo … 6=sábado)
model BarberAvailability {
  id         String @id @default(cuid())
  barberId   String
  barber     Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  /// Pausa (comida). Null = sin pausa.
  breakStart String?
  breakEnd   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barberId, dayOfWeek])
  @@index([barberId])
}

/// Excepción puntual: día libre o horario especial (festivos, vacaciones, etc.)
model BarberException {
  id         String   @id @default(cuid())
  barberId   String
  barber     Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  /// Día afectado (medianoche UTC)
  date       DateTime @db.Date
  /// true = cerrado todo el día
  isClosed   Boolean  @default(true)
  /// Horario especial si no está cerrado
  startTime  String?
  endTime    String?
  breakStart String?
  breakEnd   String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([barberId, date])
  @@index([barberId])
  @@index([date])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Appointment {
  id       String            @id @default(cuid())
  clientId String?
  name     String
  phone    String
  email    String
  /// Día de la cita (medianoche UTC)
  date     DateTime          @db.Date
  /// Hora de inicio HH:mm
  time     String
  status   AppointmentStatus @default(PENDING)

  barberId String
  barber   Barber            @relation(fields: [barberId], references: [id])

  serviceId String
  service   Service          @relation(fields: [serviceId], references: [id])

  /// Cuándo se envió el recordatorio ~24h (null = aún no)
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, barberId])
  @@index([status])
  @@index([email])
  @@index([reminderSentAt])
  // Índice único parcial (PENDING|CONFIRMED) en migración:
  // Appointment_barber_date_time_active_key
}
