// Prisma schema — Barbershop appointment booking
// Provider: SQLite (local development)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Professional who delivers the service
model Barber {
  id           String        @id @default(cuid())
  name         String
  specialty    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

/// Bookable service (haircut, beard, etc.)
model Service {
  id           String        @id @default(cuid())
  name         String
  /// Estimated duration in minutes
  duration     Int
  /// Price in cents (e.g. 2500 = €25.00) to avoid float issues
  price        Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

/// Appointment status
enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

/// Client booking linked to a barber and a service
model Appointment {
  id        String            @id @default(cuid())
  /// Optional external client identifier (CRM / auth id)
  clientId  String?
  name      String
  phone     String
  email     String
  /// Calendar date of the appointment (YYYY-MM-DD stored as DateTime at midnight UTC)
  date      DateTime
  /// Time slot in HH:mm (24h), e.g. "10:30"
  time      String
  status    AppointmentStatus @default(PENDING)

  barberId  String
  barber    Barber            @relation(fields: [barberId], references: [id])

  serviceId String
  service   Service           @relation(fields: [serviceId], references: [id])

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([date, barberId])
  @@index([email])
}
